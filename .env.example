# ── KLAVE Server ─────────────────────────────────────────────────
# Protects POST/PUT/DELETE API routes. Any string you choose.
KLAVE_API_KEY=klave-dev-key

# Protects administrative routes (e.g. policy updates).
KLAVE_OPERATOR_API_KEY=klave-operator-dev-key

# AES-256-GCM key for encrypting agent keypairs at rest.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
KLAVE_ENCRYPTION_KEY=

# Server port.
KLAVE_PORT=3000

# SQLite database path. Created automatically on first run.
KLAVE_DATABASE_URL=sqlite:klave.db?mode=rwc

# ── Solana ───────────────────────────────────────────────────────
# RPC endpoint. Defaults to devnet if not set.
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Kora (optional) ─────────────────────────────────────────────
# Kora enables gasless transactions. The server falls back to
# direct RPC submission when Kora is unavailable, so these are
# optional for getting started.

# URL of your Kora JSON-RPC server.
KORA_RPC_URL=http://localhost:8080

# API key configured in your kora.toml [api_keys] section.
# Leave empty if Kora authentication is not enabled.
KORA_API_KEY=

# Private key of the Kora fee-payer wallet (base58 encoded).
# Required for signers.toml if signer type is 'memory'.
KORA_PRIVATE_KEY=

# Public key of the Kora fee-payer wallet.
# Derive from your signer: solana-keygen pubkey ~/.config/solana/id.json
KORA_PUBKEY=

# Jupiter API key for real token pricing. If empty, Kora uses Mock pricing.
# Get one at: https://station.jup.ag/docs/apis/pricing-api
JUPITER_API_KEY=

# ── LLM ─────────────────────────────────────────────────────────
# OpenAI API key for LLM calls. Leave empty to disable.
OPENAI_API_KEY=

# Google Gemini API key for LLM calls. Leave empty to disable.
GOOGLE_API_KEY=